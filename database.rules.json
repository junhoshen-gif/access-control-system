{
  "rules": {
    "users": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "$uid === auth.uid || root.child('admins').child(auth.uid).exists()",
        ".write": "$uid === auth.uid || root.child('admins').child(auth.uid).exists()"
      }
    },
    "admins": {
      ".read": "auth != null",
      ".write": false
    },
    "files": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()",
      "$fileId": {
        ".read": "auth != null && root.child('access').child(auth.uid).child($fileId).child('granted').val() === true"
      }
    },
    "access": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "$uid === auth.uid || root.child('admins').child(auth.uid).exists()",
        ".write": "root.child('admins').child(auth.uid).exists()"
      }
    },
    "products": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).exists()"
    },
    "purchases": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "$uid === auth.uid || root.child('admins').child(auth.uid).exists()",
        ".write": "root.child('admins').child(auth.uid).exists()"
      }
    },
    "settings": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).exists()"
    },
    "logs": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()",
      ".indexOn": ["timestamp"],
      "$logId": {
        ".read": "root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || root.child('admins').child(auth.uid).exists())"
      }
    },
    "tradeMap": {
      ".read": false,
      ".write": false
    }
  }
}
