# ── ECPay 綠界金流 ────────────────────────────────────────────────
# 登入綠界後台 → 系統開發管理 → API介接資料
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
# 正式環境請換成真實的 HashKey / HashIV

# 你的綠界廠商代號 (廠商代號)
ECPAY_MERCHANT_ID=2000132

# ── Firebase ──────────────────────────────────────────────────────
# Firebase 控制台 → 專案設定 → 服務帳戶 → 產生新的私密金鑰
# 把下載的 JSON 檔內容整個貼在這裡（壓成一行）
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT",...}

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://YOUR-PROJECT-default-rtdb.firebaseio.com

# ── URLs ─────────────────────────────────────────────────────────
# 這個伺服器在 Render.com 上的公開網址（部署後填入）
SERVER_URL=https://YOUR-RENDER-APP.onrender.com

# 你的 Firebase Hosting 網站網址（付款完成後跳回）
SITE_URL=https://YOUR-PROJECT.web.app
